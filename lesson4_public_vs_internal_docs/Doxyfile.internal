PROJECT_NAME = "Doxygen Hands-On Lesson 4 (Internal)"
OUTPUT_DIRECTORY = docs/internal
INPUT = README.md include src
RECURSIVE = YES
FILE_PATTERNS = *.h *.c *.md
USE_MDFILE_AS_MAINPAGE = README.md
GENERATE_HTML = YES
GENERATE_LATEX = YES
EXTRACT_ALL = NO
EXTRACT_STATIC = YES
INTERNAL_DOCS = YES
OPTIMIZE_OUTPUT_FOR_C = YES
JAVADOC_AUTOBRIEF = YES
QUIET = YES
WARN_IF_UNDOCUMENTED = YES
