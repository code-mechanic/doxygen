PROJECT_NAME = "Doxygen Hands-On Lesson 4 (Public)"
OUTPUT_DIRECTORY = docs/public
INPUT = README.md include src/uart_console.c
RECURSIVE = YES
FILE_PATTERNS = *.h *.c *.md
USE_MDFILE_AS_MAINPAGE = README.md
GENERATE_HTML = YES
GENERATE_LATEX = YES
EXTRACT_ALL = NO
EXTRACT_STATIC = NO
INTERNAL_DOCS = NO
OPTIMIZE_OUTPUT_FOR_C = YES
JAVADOC_AUTOBRIEF = YES
QUIET = YES
WARN_IF_UNDOCUMENTED = YES
